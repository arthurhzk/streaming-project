{
  "name": "streaming-project",
  "private": true,
  "scripts": {
    "lint": "turbo run lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "build": "turbo run build",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@repo/prettier-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.0"
}
